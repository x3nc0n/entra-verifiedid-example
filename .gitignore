pids/
*.pid
*.seed
*.pid.lock

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.user
*.swp
*.swo
*~

# Docker
.dockerignore
docker-compose.override.yml

# Temporary files
tmp/
temp/
*.tmp
# Squad: ignore runtime state (logs, inbox, sessions)
