{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Entra Verified ID Employee/Guest Onboarding Demo Portal — Deploy to Azure (Container Apps)",
    "notes": [
      "Hand-aligned to infra/main.bicep because this repo does not currently include a committed ARM generation script.",
      "Evaluation path only: this template provisions infrastructure plus a bootstrap placeholder container, not the repo's real application image.",
      "Complete the primary deployment flow by running scripts/07-bootstrap-github-actions-uami.ps1, wiring GitHub Environment variables, then deploying the real image through .github/workflows/deploy.yml."
    ]
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "appName": {
      "type": "string",
      "defaultValue": "entra-vid",
      "minLength": 3,
      "maxLength": 20,
      "metadata": {
        "description": "Application name prefix used for resource naming."
      }
    },
    "azureTenantId": {
      "type": "string",
      "metadata": {
        "description": "Entra / Azure AD tenant ID."
      }
    },
    "azureClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Legacy app registration client ID. Not injected into the runtime app when managed identity auth is used."
      }
    },
    "verifiedIdAuthority": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Verified ID authority DID."
      }
    },
    "credentialManifestUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Credential manifest URL."
      }
    },
    "credentialType": {
      "type": "string",
      "defaultValue": "VerifiedEmployee",
      "metadata": {
        "description": "Credential type name."
      }
    },
    "identityPassEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "IdentityPass endpoint URL."
      }
    },
    "fido2RpName": {
      "type": "string",
      "defaultValue": "Entra Verified ID Demo",
      "metadata": {
        "description": "FIDO2 relying party display name."
      }
    },
    "fido2RpId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "FIDO2 relying party ID (usually the deployed Container App FQDN)."
      }
    },
    "fido2Origin": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "FIDO2 allowed origin including scheme (for example https://<container-app-fqdn>)."
      }
    },
    "demoMode": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable demo mode (loosened auth for demo purposes)."
      }
    }
  },
  "variables": {
    "containerAppEnvironmentName": "[concat(parameters('appName'), '-cae')]",
    "containerAppName": "[concat(parameters('appName'), '-app')]",
    "lawName": "[concat(parameters('appName'), '-law')]",
    "appInsightsName": "[concat(parameters('appName'), '-ai')]",
    "saName": "[take(toLower(concat(replace(parameters('appName'), '-', ''), uniqueString(resourceGroup().id))), 24)]",
    "kvSuffix": "[uniqueString(resourceGroup().id)]",
    "kvNameRaw": "[concat(parameters('appName'), '-kv-', variables('kvSuffix'))]",
    "kvName": "[if(greater(length(variables('kvNameRaw')), 24), substring(variables('kvNameRaw'), 0, 24), variables('kvNameRaw'))]",
    "acrName": "[take(toLower(concat(replace(parameters('appName'), '-', ''), uniqueString(resourceGroup().id, parameters('appName'), 'acr'))), 50)]",
    "acrLoginServer": "[concat(variables('acrName'), '.azurecr.io')]",
    "tags": {
      "project": "entra-verifiedid-example",
      "environment": "demo"
    },
    "appRuntimeUamiName": "[concat('uami-', parameters('appName'), '-app')]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('lawName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30,
        "features": {
          "enableLogAccessUsingOnlyResourcePermissions": true
        }
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "kind": "web",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName'))]"
      ],
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName'))]",
        "RetentionInDays": 30,
        "IngestionMode": "LogAnalytics",
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('saName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "supportsHttpsTrafficOnly": true,
        "accessTier": "Hot"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('saName'), '/default/artifacts')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('saName'))]"
      ],
      "properties": {
        "publicAccess": "None"
      }
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[variables('acrName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": false,
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('kvName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[subscription().tenantId]",
        "softDeleteRetentionInDays": 7,
        "enableSoftDelete": true,
        "enablePurgeProtection": true,
        "enableRbacAuthorization": true
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[concat(variables('kvName'), '/azure-client-secret')]",
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ],
      "properties": {
        "value": "PLACEHOLDER--run-bootstrap-to-set",
        "attributes": {
          "enabled": true
        }
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[concat(variables('kvName'), '/identitypass-key')]",
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ],
      "properties": {
        "value": "PLACEHOLDER--run-bootstrap-to-set",
        "attributes": {
          "enabled": true
        }
      }
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[variables('appRuntimeUamiName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]"
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('containerAppEnvironmentName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName'))]"
      ],
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName')), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName')), '2023-09-01').primarySharedKey]"
          }
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[variables('containerAppName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "identity": {
        "type": "SystemAssigned,UserAssigned",
        "userAssignedIdentities": {
          "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('appRuntimeUamiName'))]": {}
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('containerAppEnvironmentName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('appRuntimeUamiName'))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ],
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('containerAppEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 3000,
            "transport": "auto",
            "allowInsecure": false
          }
        },
        "template": {
          "containers": [
            {
              "name": "portal",
              "image": "mcr.microsoft.com/mirror/docker/library/node:20-bookworm-slim",
              "command": [
                "node"
              ],
              "args": [
                "-e",
                "const http=require(\"http\");const port=Number(process.env.PORT||3000);http.createServer((req,res)=>{res.statusCode=200;res.setHeader(\"Content-Type\",\"text/plain\");res.end(req.url===\"/health\"?\"ok\":\"Infrastructure is ready. Deploy the real portal image through GitHub Actions.\");}).listen(port,\"0.0.0.0\");"
              ],
              "env": [
                {
                  "name": "WEBSITE_NODE_DEFAULT_VERSION",
                  "value": "~20"
                },
                {
                  "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
                  "value": "true"
                },
                {
                  "name": "NODE_ENV",
                  "value": "production"
                },
                {
                  "name": "AZURE_TENANT_ID",
                  "value": "[parameters('azureTenantId')]"
                },
                {
                  "name": "AZURE_CLIENT_ID",
                  "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('appRuntimeUamiName')), '2023-01-31').clientId]"
                },
                {
                  "name": "VC_ISSUER_AUTHORITY",
                  "value": "[parameters('verifiedIdAuthority')]"
                },
                {
                  "name": "VC_CREDENTIAL_MANIFEST_URL",
                  "value": "[parameters('credentialManifestUrl')]"
                },
                {
                  "name": "VC_CREDENTIAL_TYPE",
                  "value": "[parameters('credentialType')]"
                },
                {
                  "name": "IDENTITYPASS_API_ENDPOINT",
                  "value": "[parameters('identityPassEndpoint')]"
                },
                {
                  "name": "FIDO2_RP_NAME",
                  "value": "[parameters('fido2RpName')]"
                },
                {
                  "name": "FIDO2_RP_ID",
                  "value": "[parameters('fido2RpId')]"
                },
                {
                  "name": "FIDO2_ORIGIN",
                  "value": "[parameters('fido2Origin')]"
                },
                {
                  "name": "KEY_VAULT_URL",
                  "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), '2023-07-01').vaultUri]"
                },
                {
                  "name": "DEMO_MODE",
                  "value": "[string(parameters('demoMode'))]"
                },
                {
                  "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
                  "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').InstrumentationKey]"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
                },
                {
                  "name": "ApplicationInsightsAgent_EXTENSION_VERSION",
                  "value": "~3"
                }
              ],
              "resources": {
                "cpu": 0.5,
                "memory": "1Gi"
              }
            }
          ],
          "scale": {
            "minReplicas": 0,
            "maxReplicas": 2
          }
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2024-03-01', 'Full').identity.principalId, 'Key Vault Secrets User')]",
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
        "[resourceId('Microsoft.App/containerApps', variables('containerAppName'))]"
      ],
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2024-03-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2024-03-01', 'Full').identity.principalId, 'AcrPull')]",
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[resourceId('Microsoft.App/containerApps', variables('containerAppName'))]"
      ],
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2024-03-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]"
      }
    }
  ],
  "outputs": {
    "webAppName": {
      "type": "string",
      "value": "[variables('containerAppName')]"
    },
    "webAppHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2024-03-01').properties.configuration.ingress.fqdn]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), '2023-07-01').vaultUri]"
    },
    "appInsightsKey": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').InstrumentationKey]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('saName')]"
    },
    "containerRegistryName": {
      "type": "string",
      "value": "[variables('acrName')]"
    },
    "containerRegistryLoginServer": {
      "type": "string",
      "value": "[variables('acrLoginServer')]"
    },
    "containerAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2024-03-01', 'full').identity.principalId]"
    },
    "appRuntimeManagedIdentityName": {
      "type": "string",
      "value": "[variables('appRuntimeUamiName')]"
    },
    "appRuntimeManagedIdentityClientId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('appRuntimeUamiName')), '2023-01-31').clientId]"
    },
    "appRuntimeManagedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('appRuntimeUamiName')), '2023-01-31').principalId]"
    }
  }
}
